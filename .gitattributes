# Auto detect text files and perform LF normalization
* text=auto

# Explicitly set line endings for source files to LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.toml  text eol=lf
*.sql   text eol=lf
*.env   text eol=lf

# Binary files — never diff or merge these
*.sqlite binary
*.sqlite3 binary
*.db     binary
*.db3    binary

# Media & assets — treat as binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.svg  text eol=lf
*.mp3  binary
*.ogg  binary
*.wav  binary
*.wasm binary
