# ============================================================
# KingsGauntlet Chess Arena — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# NODE_ENV=production

# ── PostgreSQL ───────────────────────────────────────────────
# Local dev:
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/kingsgauntlet?sslmode=disable
# Production (Railway / Supabase / Render):
# DATABASE_URL=postgresql://user:pass@host:5432/kingsgauntlet?sslmode=require

# ── MongoDB ──────────────────────────────────────────────────
# Local dev:
MONGODB_URI=mongodb://localhost:27017/kingsgauntlet
# Production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/kingsgauntlet?retryWrites=true&w=majority

# ── Authentication ───────────────────────────────────────────
# Must be at least 32 characters long in production!
JWT_SECRET=replace_this_with_a_minimum_32_char_random_secret_key
JWT_EXPIRES_IN=7d

# ── Security ─────────────────────────────────────────────────
# BCrypt hash rounds (10 = fast dev, 12 = production recommended)
BCRYPT_ROUNDS=12
# Login rate limit: max attempts per IP per window
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=60000

# ── CORS ─────────────────────────────────────────────────────
# Local development:
FRONTEND_URL=http://localhost:5173
# Production Netlify deployment:
# FRONTEND_URL=https://your-app-name.netlify.app
